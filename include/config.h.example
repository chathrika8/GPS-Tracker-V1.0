#pragma once

// ============================================================
// GPS Tracker — Configuration Template
// Copy this file to config.h and fill in your values.
// config.h is gitignored to keep credentials out of version control.
// ============================================================

// — Pin Definitions —
#define SIM800L_TX    20
#define SIM800L_RX    21
#define SIM800L_RST   0       // Using GPIO0 (PWRKEY equivalent)
#define SIM800L_RI    10      // Using GPIO10
#define GPS_TX        5       // NEO-6M RX
#define GPS_RX        4       // NEO-6M TX
#define I2C_SDA       8       // OLED SDA (pull-up inherently secures GPIO8 strapping HIGH)
#define I2C_SCL       9       // OLED SCL (pull-up inherently secures GPIO9 strapping HIGH)
#define BTN_A         3       // Button SELECT/CALL
#define BTN_B         1       // Button BACK/HANG

// — GPRS —
// Set to your carrier's APN. Leave USER/PASS blank for most carriers.
#define GPRS_APN      "your.carrier.apn"
#define GPRS_USER     ""
#define GPRS_PASS     ""

// — Wi-Fi (OTA & commands only) —
#define WIFI_SSID     "YourWiFiSSID"
#define WIFI_PASS     "YourWiFiPassword"

// — Cloudflare Proxy —
// The firmware posts JSON to this host/path over raw TCP (port 80).
// Set up a Cloudflare Worker or similar HTTPS proxy to forward to Supabase.
#define PROXY_HOST      "api.yourdomain.com"
#define PROXY_PATH      "/uplink"
#define SUPABASE_TABLE  "locations"

// — GitHub OTA —
// Repository hosting firmware releases (tag format: v1.x.x)
#define GITHUB_REPO_OWNER  "youruser"
#define GITHUB_REPO_NAME   "gps-tracker-firmware"
#define GITHUB_TOKEN       ""   // Optional: for private repos (Personal Access Token)

// — Device Identity —
#define DEVICE_ID     "GPS-001"    // Unique ID sent with every packet
#define FW_VERSION    "1.0.0"      // Must match GitHub Release tag (without 'v')

// — Timing (ms) —
#define GPS_READ_INTERVAL       400
#define BUFFER_INTERVAL_MOVING  10000     // 10s when moving
#define BUFFER_INTERVAL_IDLE    10000     // 10s when stationary
#define SPEED_THRESHOLD_KMH     2.0       // moving vs stationary threshold
#define DISPLAY_REFRESH         100       // 10 Hz UI refresh
#define OTA_CHECK_INTERVAL      21600000  // 6 hours
#define UPLINK_BATCH_SIZE_MOVING  1       // packets per uplink cycle when moving
#define UPLINK_BATCH_SIZE_IDLE    1       // packets per uplink cycle when idle
#define UPLINK_INTERVAL_MOVING    0       // ms — TCP latency provides natural pacing
#define UPLINK_INTERVAL_IDLE      10000   // ms — 10s between uplink cycles when stationary
#define BUTTON_DEBOUNCE         50

// — Tracking Schedule (defaults, overridden by dashboard) —
#define SCHEDULE_ENABLED  false

// — GPS UART —
#define GPS_BAUD_DEFAULT  9600
#define GPS_BAUD_TARGET   9600    // Stay at 9600 to prevent parse failures
#define GPS_UPDATE_RATE   5       // Hz

// — Display —
#define OLED_WIDTH   128
#define OLED_HEIGHT  128
#define OLED_ADDR    0x3C
